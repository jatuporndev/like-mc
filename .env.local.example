# ---------------------------------------------------------------------------
# Firebase Web (client) config — safe to expose to the browser.
# Project settings → General → Your apps → Web app → SDK setup and config
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Firebase Admin (server only) — NEVER expose these.
# Project settings → Service accounts → Generate new private key.
# Paste the private key with literal \n for newlines, wrapped in quotes.
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# football-data.org API token (server only).
# Register a free account: https://www.football-data.org/client/register
# ---------------------------------------------------------------------------
FOOTBALL_DATA_API_TOKEN=

# ---------------------------------------------------------------------------
# Admin access control.
# Comma-separated list of emails allowed into /admin and admin APIs.
# ---------------------------------------------------------------------------
ADMIN_EMAILS=you@example.com
NEXT_PUBLIC_ADMIN_EMAILS=you@example.com

# ---------------------------------------------------------------------------
# Shared secret for machine-to-machine sync (Google Apps Script / cron).
# Sent as: Authorization: Bearer <SYNC_SECRET>
# Generate a strong random value, e.g.  openssl rand -hex 32
# ---------------------------------------------------------------------------
SYNC_SECRET=
